index:
  description: |
    Video indexing and search pipeline using Milvus.
  inputs:
    index_name:
      - writer.index_name
  pipeline:
    components:
      router:
        type: src.haystack.components.routers.IndexTypeRouter
      embedder:
        init_parameters:
          url: "{{{ COSMOS_EMBED_NIM_URI }}}"
          batch_size: 64
        type: src.haystack.components.video.cosmos_video_embedder.CosmosVideoDocumentEmbedder
      document_batcher:
        init_parameters:
          type_alias: haystack.Document
        type: src.haystack.components.joiners.Concatenate
      writer:
        init_parameters:
          document_store:
            type: src.haystack.components.milvus.document_store.MilvusDocumentStore
            init_parameters:
              uri: "{{{ MILVUS_DOCUMENT_STORE_URI }}}"
              api_key: null
              database: "{{{ MILVUS_DB }}}"
              embedding_dim: 256  # Cosmos-embed produces 256 dimensions
              similarity: "IP"
          policy: OVERWRITE
        type: src.haystack.components.milvus.document_writer.MilvusDocumentWriter
    connections:
      - sender: router.to_index
        receiver: embedder.documents
      - sender: embedder.documents
        receiver: document_batcher.input
      - sender: router.embedded
        receiver: document_batcher.input
      - sender: document_batcher.output
        receiver: writer.documents
    max_loops_allowed: 100
    metadata: {}

query:
  inputs:
    query:
      - router.query
    top_k:
      - retriever.top_k
      - reranker.top_k
    reconstruct:
      - retriever.reconstruct
    index_name:
      - retriever.index_name
    search_params:
      - retriever.search_params
    filters:
      - retriever.filters
    labelled_embeddings:
      - query_learner.labelled_embeddings
  pipeline:
    components:
      router:
        type: src.haystack.components.routers.QueryTypeRouter
      text_embedder:
        init_parameters:
          url: "{{{ COSMOS_EMBED_NIM_URI }}}"
        type: src.haystack.components.video.cosmos_video_embedder.CosmosTextEmbedder
      video_embedder:
        init_parameters:
          url: "{{{ COSMOS_EMBED_NIM_URI }}}"
        type: src.haystack.components.video.cosmos_video_embedder.CosmosVideoEmbedder
      session_segment_embedder:
        init_parameters:
          url: "{{{ COSMOS_EMBED_NIM_URI }}}"
        type: src.haystack.components.video.cosmos_video_embedder.CosmosSessionSegmentEmbedder
      embedding_batcher:
        init_parameters:
          type_alias: typing.List[float]
        type: src.haystack.components.joiners.Concatenate
      query_learner:
        type: src.haystack.components.linear_probe.query_learner.LinearProbeQueryLearner
      retriever:
        init_parameters:
          document_store:
            type: src.haystack.components.milvus.document_store.MilvusDocumentStore
            init_parameters:
              uri: "{{{ MILVUS_DOCUMENT_STORE_URI }}}"
              api_key: null
              database: "{{{ MILVUS_DB }}}"
              embedding_dim: 256
              similarity: "IP"
          filters: null
          top_k: 10
          reconstruct: False
        type: src.haystack.components.milvus.embedding_retriever.MilvusEmbeddingRetriever
      document_joiner:
        init_parameters:
          type_alias: haystack.Document
        type: src.haystack.components.joiners.Flatten
      reranker:
        type: src.haystack.components.rankers.ScoreRanker
    connections:
      # route to specific embedders
      - sender: router.texts
        receiver: text_embedder.texts
      - sender: router.videos
        receiver: video_embedder.video_urls
      - sender: router.clips
        receiver: session_segment_embedder.clips

      # batch embeddings
      - sender: router.embeddings
        receiver: embedding_batcher.input
      - sender: video_embedder.embeddings
        receiver: embedding_batcher.input
      - sender: text_embedder.embeddings
        receiver: embedding_batcher.input
      - sender: session_segment_embedder.embeddings
        receiver: embedding_batcher.input

      # query learner
      - sender: embedding_batcher.output
        receiver: query_learner.grounding_embeddings

      # batched retrieval
      - sender: query_learner.query_embeddings
        receiver: retriever.query_embeddings
      - sender: retriever.documents
        receiver: document_joiner.input

      # final re-rank
      - sender: document_joiner.output
        receiver: reranker.documents

    max_loops_allowed: 100
    metadata: {}
