# ==============================================
# Cosmos Video Dataset Search - Environment Configuration
# ==============================================
# Copy this file to .env and fill in your actual values
# Example: cp .env.example .env

# ==============================================
# Required API Keys
# ==============================================

# NVIDIA API Key (REQUIRED)
# Get your NGC key
NVIDIA_API_KEY=<your_api_key>

# ==============================================
# Data Directory
# ==============================================

# Path to your data directory (REQUIRED)
# This directory should contain your video/image files for indexing
DATA_DIR=/path/to/your/data

# ==============================================
# Infrastructure Configuration
# ==============================================

# LocalStack (AWS S3 emulation) Credentials
AWS_ACCESS_KEY_ID=test
AWS_SECRET_ACCESS_KEY=test
AWS_DEFAULT_REGION=us-east-1
AWS_ENDPOINT_URL=http://localstack:4566

# ==============================================
# GPU Configuration
# ==============================================

# Which GPU(s) to use for Milvus (comma-separated device IDs)
MILVUS_CUDA_VISIBLE_DEVICES=0

# Number of GPUs for Cosmos Embed NIM
COSMOS_EMBED_GPUS=1

# ==============================================
# Container Images
# ==============================================

# Cosmos Embed NIM Image
COSMOS_EMBED_IMAGE=nvcr.io/nim/nvidia/cosmos-embed1:1.0.0

# Cosmos VDS Web UI Image
COSMOS_VDS_WEB_UI_IMAGE=nvcr.io/nvidia/blueprint/cosmos-cds-ui:1.0.0

# ==============================================
# NIM Configuration
# ==============================================

# Triton verbose logging (0=off, 1=on)
NIM_TRITON_LOG_VERBOSE=0

# NIM log level (DEFAULT, INFO, WARNING, ERROR)
NIM_LOG_LEVEL=DEFAULT

# ==============================================
# Visual Search Service Configuration
# ==============================================

# Gunicorn server configuration
GUNICORN_PORT=8888
GUNICORN_WORKERS=2
GUNICORN_TIMEOUT=600

# Maximum documents per upload batch
MAX_DOCS_PER_UPLOAD=3200

# Milvus connection
MILVUS_DOCUMENT_STORE_URI=http://milvus:19530
MILVUS_DB=""

# Cosmos Embed NIM endpoint
COSMOS_EMBED_NIM_URI=http://cosmos-embed:8000

# Allowed search pipelines (comma-separated)
ALLOWED_PIPELINES=cosmos_video_search_milvus

# Logging level (DEBUG, INFO, WARNING, ERROR)
VISUAL_SEARCH_LOG_LEVEL=DEBUG

# ==============================================
# Web UI Configuration
# ==============================================

# API endpoint URL for the web UI
CDS_API_URL=http://localhost:8888/v1

# CDN URL for serving media assets
CDS_CDN_URL=http://localhost:4566/cosmos-test-bucket

# Web UI base URL
CDS_UI_URL=http://localhost:8080/
